{
	"exportDir": "./pi-session-exports",
	"includeSubdirs": false,
	"includeThinking": false,
	"includeToolCalls": true,
	"includeToolResults": false,
	"maxCharsPerMessage": 0,
	"sessionsDir": null,
	"replacements": [
		{ "name": "company", "find": "Acme Corporation", "replace": "[COMPANY]" },
		{ "name": "internal-host", "find": "\\bprod-db-\\d+\\.internal\\b", "replace": "[DB_HOST]", "regex": true, "flags": "gi" }
	],
	"redactionCommands": [
		{
			"name": "gitleaks",
			"command": "gitleaks",
			"args": ["detect", "--no-banner", "--no-git", "--report-format", "json", "--report-path", "{report}", "--source", "{file}"],
			"mode": "scan",
			"onFinding": "warn",
			"maskWith": "[REDACTED-SECRET]"
		},
		{
			"name": "trufflehog",
			"command": "trufflehog",
			"args": ["filesystem", "{file}", "--json", "--no-update"],
			"mode": "scan",
			"onFinding": "warn",
			"maskWith": "[REDACTED-SECRET]"
		}
	]
}
